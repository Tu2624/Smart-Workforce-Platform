# ============================================================
# Smart Workforce Platform — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Server
PORT=3001
NODE_ENV=development          # development | production | test

# Database — MySQL 8
DB_HOST=localhost
DB_PORT=3306                  # Docker: 3307 (mapped to host port to avoid conflicts)
DB_NAME=smart_workforce
DB_USER=root
DB_PASSWORD=your_db_password  # REQUIRED — set a strong password

# JWT — REQUIRED, must be set or server will refuse to start
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# CORS — frontend origin allowed to connect
CORS_ORIGIN=http://localhost:5173

# Background jobs (cron syntax)
CRON_PAYROLL_SCHEDULE="0 0 * * *"    # daily midnight — auto-detect absent
CRON_REMINDER_SCHEDULE="*/30 * * * *" # every 30 min — low-registration alert
